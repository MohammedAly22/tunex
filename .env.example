# TuneX Configuration
# Copy this file to .env and fill in your values

# LLM Provider for Agents (openai, anthropic, cohere, ollama)
TUNEX_LLM_PROVIDER=anthropic
TUNEX_LLM_MODEL=claude-sonnet-4-6

# API Keys (fill in the one matching your provider)
TUNEX_ANTHROPIC_API_KEY=
TUNEX_OPENAI_API_KEY=
TUNEX_COHERE_API_KEY=

# Ollama (only if using ollama provider)
TUNEX_OLLAMA_ENDPOINT=http://localhost:11434

# HuggingFace (optional, for model publishing)
TUNEX_HF_TOKEN=
TUNEX_HF_ORGANIZATION=
